    "viewer",
    "monaco"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "devDependencies": {
    "electron": "^33.0.0"
  },
  "dependencies": {
    "chokidar": "^5.0.0"
  }
