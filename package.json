{
  "name": "gdiff-viewer",
  "version": "1.0.5",
  "description": "Lightweight Monaco-based git diff viewer — runs in your browser",
  "main": "main.js",
  "bin": {
    "gdiff": "bin/gdiff.js",
    "gdiff-viewer": "bin/gdiff.js"
  },
  "files": [
    "bin/",
    "server.js",
    "index.html",
    "favicon.png",
    "gdiff.png",
    "themes.json",
    "THEMES_LICENSE"
  ],
  "scripts": {
    "start": "electron .",
    "serve": "node server.js",
    "dev": "electron . --enable-logging"
